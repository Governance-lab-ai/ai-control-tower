# AI Governance Control Tower
# Keep source, docs, migrations, and infra templates tracked.
# Keep local secrets, generated artifacts, caches, and demo data out of git.

# Local agent/runtime state
.agents/
.codex/

# Environment and secrets
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*.jks
*.keystore
secrets/
.secrets/

# Python / FastAPI backend
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
pip-wheel-metadata/

# Alembic / local backend runtime
backend/.env
backend/.env.*
!backend/.env.example
backend/.local/
backend/.cache/
backend/uploads/

# Node / Next.js frontend
node_modules/
.next/
out/
.vercel/
.turbo/
.swc/
frontend/.env.local
frontend/.env.*.local
!frontend/.env.example
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.turbo/

